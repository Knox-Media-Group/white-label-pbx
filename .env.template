# ============================================================
# Knox Command Center - Environment Variables Template
# Copy to .env and fill in values before starting the server.
# ============================================================

# --- Core ---
NODE_ENV=production
PORT=3000

# --- Database (MySQL) ---
DATABASE_URL=mysql://user:password@localhost:3306/knox_pbx

# --- OAuth / Auth ---
VITE_APP_ID=your-app-id
VITE_OAUTH_PORTAL_URL=https://oauth.example.com
OAUTH_SERVER_URL=https://oauth-api.example.com
OWNER_OPEN_ID=admin-open-id

# --- Session / JWT ---
# REQUIRED in production: min 32 chars. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# Session time-to-live in milliseconds (default: 86400000 = 24h in prod, 604800000 = 7d in dev)
SESSION_TTL_MS=86400000

# --- CORS ---
# Comma-separated list of allowed origins (required in production)
ALLOWED_ORIGINS=https://knox.example.com

# --- Stale-State ---
# Data older than this (ms) shows a staleness warning in the UI (default: 300000 = 5 min)
STALE_THRESHOLD_MS=300000

# --- SignalWire ---
SIGNALWIRE_PROJECT_ID=
SIGNALWIRE_API_TOKEN=
SIGNALWIRE_SPACE_URL=

# --- S3 Storage ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# --- LLM / Forge ---
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
