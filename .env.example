# ============ Database ============
# PostgreSQL connection string (Supabase or self-hosted)
DATABASE_URL=postgresql://user:password@host:5432/database

# ============ Auth ============
# Secret key for signing JWT tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your-secret-key-here
# OAuth app ID from your auth provider
VITE_APP_ID=
# OAuth portal URL (must be VITE_ prefixed for client access)
VITE_OAUTH_PORTAL_URL=
# OAuth server URL (server-side)
OAUTH_SERVER_URL=
# Your admin user's OpenID (auto-assigned admin role)
OWNER_OPEN_ID=

# ============ LLM (AI features) ============
# API URL and key for AI-powered call summaries and routing
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ============ Telnyx (Primary Carrier) ============
# Get these from https://portal.telnyx.com
TELNYX_API_KEY=KEYxxxxx
TELNYX_SIP_CONNECTION_ID=
TELNYX_MESSAGING_PROFILE_ID=
# Webhook signing secret from Telnyx portal
TELNYX_WEBHOOK_SECRET=
TELNYX_SIP_DOMAIN=sip.telnyx.com

# ============ Retell AI (AI Receptionist) ============
# Get from https://www.retellai.com/dashboard
RETELL_API_KEY=key_xxxxx
# Retell SIP origination URI (for Telnyx -> Retell call forwarding)
RETELL_SIP_URI=sip:xxxxx.sip.livekit.cloud

# ============ Webhook URL ============
# Your public server URL (used for Telnyx/Retell webhook callbacks)
# Must be HTTPS in production
WEBHOOK_URL=https://your-domain.com

# ============ AWS S3 (Call Recordings Storage) ============
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-pbx-recordings-bucket

# ============ Server ============
NODE_ENV=development
PORT=3000
